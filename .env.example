OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=openai:gpt-4o-mini

# Optional. If omitted, the script uses this lab folder when it is a Git repo.
# MCP_GIT_REPOSITORY=/absolute/path/to/another/git/repository

# Optional Trello REST API demo.
# When the three required values are set, the script uses the official Trello
# API to create one real demo card. If TRELLO_LIST_ID is omitted, the script
# creates or reuses TRELLO_LIST_NAME.
# Trello is a third-party external app integration. Use at your own discretion:
# prefer an empty test board and a temporary/revocable token.
# TRELLO_API_KEY=your_trello_api_key_here
# TRELLO_TOKEN=your_trello_token_here
# TRELLO_BOARD_ID=your_trello_board_id_here
# TRELLO_LIST_NAME=MCP Demo
# TRELLO_LIST_ID=optional_existing_trello_list_id_here
